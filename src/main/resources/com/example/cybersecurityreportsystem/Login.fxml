<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextInputControl?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.TextField?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.crs.controller.Logincontroller"
      xmlns="http://javafx.com/javafx"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f0f2f5;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Login"
           style="-fx-font-size: 28; -fx-font-weight: bold;" />

    <GridPane hgap="10" vgap="10" maxWidth="320">
        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="emailField"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="0"
                          promptText="Enter your email"/>

        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <PasswordField fx:id="passwordField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="1"
                       promptText="Enter your password"/>

        <Button fx:id="loginButton"
                text="Login"
                onAction="#handleLogin"
                GridPane.columnIndex="0"
                GridPane.rowIndex="2"
                GridPane.columnSpan="2"
                style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <Button fx:id="signUpButton"
                text="Sign Up"
                GridPane.columnIndex="0"
                GridPane.rowIndex="3"
                GridPane.columnSpan="2"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </GridPane>

    <Label fx:id="messageLabel"
           text=""
           style="-fx-font-size: 14;"/>
</VBox>